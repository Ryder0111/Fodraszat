@model FodraszatIdopont.Models.ViewModels.RegisterViewModel;
@{if(TempData["error_msg"]!=null){
	<div class="alert alert-danger">@TempData</div>
}
}

<h1 class="display-4 fw-bold text-center">Regisztráció</h1>
<div class="fs-5 text-center">Hozzon létre fiókot, hogy egyszerűbben foglalhasson időpontot!</div>

<form action="Registration" method="post" class="w-50 mx-auto border border-3 rounded shadow p-4 mt-4">
    <div class="form-group row mb-3 mt-3">
        <label class="col-sm-2 col-form-label">Teljes név</label>
        <div class="col-sm-10">
            <input type="text" asp-for=@Model.Name class="form-control" placeholder="Példa Béla">
        </div>
    </div>
    <div class="form-group row mb-3">
        <label class="col-sm-2 col-form-label">Email cím</label>
        <div class="col-sm-10">
            <input type="text" asp-for=@Model.Email class="form-control" placeholder="email@pelda.com">
        </div>
    </div>
    <div class="form-group row mb-3">
        <label class="col-sm-2 col-form-label">Jelszó</label>
        <div class="col-sm-10">
            <input type="password" asp-for=@Model.Password class="form-control" placeholder="Jelszó">
        </div>
    </div>
    <div class="form-group row mb-3">
        <label class="col-sm-2 col-form-label">Jelszó mégegyszer</label>
        <div class="col-sm-10">
            <input type="password" asp-for=@Model.ConfirmPassword class="form-control" placeholder="Jelszó">
        </div>
    </div>
    <div class="form-group row">
        <label class="col-sm-2 col-form-label">Nemed</label>
        <div class="col-sm-10">
            <div class="form-check">
                <input class="form-check-input" type="radio" name="sexRadio" value="Male" checked>
                <label class="form-check-label">
                    Férfi
                </label>
            </div>
            <div class="form-check">
                <input class="form-check-input" type="radio" name="sexRadio" value="Famale">
                <label class="form-check-label">
                    Nő
                </label>
            </div>
            <div class="form-check">
                <input class="form-check-input" type="radio" name="sexRadio" value="None">
                <label class="form-check-label">
                    Egyéb
                </label>
            </div>
        </div>
    </div>
    <button type="submit" class="btn btn-primary w-100 mt-3">Regisztráció</button>
</form>