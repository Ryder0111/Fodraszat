@model FodraszatIdopont.Models.AppointmentDTO;
@{
    if (TempData["msg"] != null)
    {
        <div class="alert alert-success w-50 text-center mx-auto">@TempData["msg"]</div>
    }
}

<h1 class="display-4 fw-bold text-center">Időpontfoglalás</h1>

<form asp-action="MAAppointment" method="post" class="w-50 mx-auto border border-3 rounded shadow p-4 mt-4">
    @{
        Html.AntiForgeryToken();
        if (TempData["error_msg"] != null)
        {
            <div class="alert alert-danger text-center">@TempData["error_msg"]</div>
        }
    }
    
    <div class="row g-4">
        <div class="col-md-6">
            <label class="form-label fw-bold fs-5">Válassz fodrászt</label>
                <select id="hairdresserSelect" class="form-select form-select-lg shadow-sm"
                    asp-for="Appointment.HairdresserId">
                <option value="">--Válassz fodrászt--</option>

                @foreach(var item in Model.Hairdressers)
                {
                    <option value="@item.UserId" asp>@item.Name</option>
                }
            </select>
        </div>

        <div class="col-md-6">
            <label class="form-label fw-bold fs-5">Válassz szolgáltatást</label>
            <select id="serviceSelect" class="form-select form-select-lg shadow-sm"
                    asp-for="Appointment.ServiceId">
                <option value="">--Válassz szolgáltatást--</option>
                @foreach (var item in Model.Services)
                {

                        <option data-duration="@item.DurationInMinute" value="@item.ServiceId">@item.Name</option>
                }
            </select>
        </div>
    </div>

    <div id="calendarWrapper" class="d-none mt-4 shadow rounded bg-white p-3">
        <div id="color-calendar"></div>
    </div>


    <div id="timeSlotsContainer" class="d-none mt-4">
        <h5 class="fw-bold">Elérhető időpontok:</h5>
        <div id="timeSlots" class="list-group"></div>
    </div>

    <button type="submit" class="btn btn-primary w-100 mt-3">Időpont lefoglalása</button>
</form>
<script src="~/js/MAAppointment_Calendar.js"></script>