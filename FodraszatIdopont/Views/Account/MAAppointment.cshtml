@model FodraszatIdopont.Models.AppointmentDTO;
<body>
@{
    if (TempData["msg"] != null)
    {
        <div class="alert alert-success w-50 text-center mx-auto">@TempData["msg"]</div>
    }
}

<h1 class="display-4 fw-bold text-center">Időpontfoglalás</h1>

<form asp-action="MAAppointment" method="post" class="w-50 mx-auto border border-3 rounded shadow p-4 mt-4">
    @{
        Html.AntiForgeryToken();
        if (TempData["error_msg"] != null)
        {
            <div class="alert alert-danger text-center">@TempData["error_msg"]</div>
        }
    }
    
    <div class="row g-4">
        <div class="col-md-6">
            <label class="form-label fw-bold fs-5">Válassz fodrászt</label>
            <select class="form-select form-select-lg shadow-sm"
                    asp-for="Appointment.HairdresserId">
                <option value="">--Válassz fodrászt--</option>

                @foreach(var item in Model.Hairdressers)
                {
                    <option value="@item.UserId" asp>@item.Name</option>
                }
            </select>
        </div>

        <div class="col-md-6">
            <label class="form-label fw-bold fs-5">Válassz szolgáltatást</label>
            <select class="form-select form-select-lg shadow-sm"
                    asp-for="Appointment.ServiceId">
                <option value="">--Válassz szolgáltatást--</option>
                @foreach (var item in Model.Services)
                {
                    <option value="@item.ServiceId">@item.Name</option>
                }
            </select>
        </div>
    </div>

    @* <div class="row g-4 mb-4">
        <div class="col-12">
            <label class="form-label fw-bold fs-5 text-primary">Válassz időpontot a naptárból</label>
                <div id="color-calendar" class="shadow rounded-4 p-3"></div>
        </div>
    </div> *@

    <div id="color-calendar" style="max-width: 600px; margin: 0 auto;"></div>

    <input type="hidden" asp-for="Appointment.StartTime" id="selectedStartTime" />

    <button type="submit" class="btn btn-primary w-100 mt-3">Időpont lefoglalása</button>
</form>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            new Calendar({
                container: '#color-calendar',
                calendarSize: 'large',          // vagy 'small'
                initialSelectedDate: new Date(), // ma
                theme: 'basic',
                primaryColor: '#007bff',        // Bootstrap kék, hogy illeszkedjen
                headerColor: '#343a40',
                headerBackgroundColor: '#f8f9fa',
                weekdaysColor: '#6c757d',

                // Események / foglalt napok (piros karikákhoz)
                eventsData: [
                    // Példa foglalt nap – később backend-ből töltöd
                    {
                        start: '2026-03-10T00:00:00',
                        end: '2026-03-10T23:59:59',
                        name: 'Foglalt',
                        color: '#dc3545'  // piros
                    }
                ],

                eventBulletMode: 'multiple',    // Több foglalás naponta is látható
                disableDayClick: false          // Kattintható napok

                // Ha kell: startWeekday: 1 (hétfővel kezdjen)
            });
        });

                function loadEvents(hairdresserId) {
            fetch(`/Account/GetBookedDays?hairdresserId=${hairdresserId}`)
                .then(res => res.json())
                .then(data => {
                    // data = ["2026-03-10", "2026-03-15", ...]
                    let events = data.map(date => ({
                        start: date,
                        end: date,
                        name: 'Foglalt',
                        color: '#dc3545'
                    }));
                    calendar.setOption('eventsData', events);
                    calendar.refetchEvents();  // Frissítés
                });
        }
    </script>
</body>